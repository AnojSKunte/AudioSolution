# 🌐 AUDIO SOLUTION - PRODUCTION CONFIGURATION
# Copy these to your hosting provider (Render, Vercel, Heroku, etc.)

# --- SERVER CONFIG ---
NODE_ENV=production
PORT=5000
# Update this with your actual backend URL after deployment
BACKEND_URL=https://your-audio-backend.onrender.com
# Update this with your frontend URL
FRONTEND_URL=https://your-audio-app.vercel.app

# --- DATABASE (Get these from Supabase) ---
DB_USER=postgres
DB_HOST=db.your-supabase-project.supabase.co
DB_NAME=postgres
DB_PASSWORD=your-secure-db-password
DB_PORT=5432

# --- SECURITY ---
# Run 'node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"' to generate
JWT_SECRET=your-random-32-character-secret-key

# --- PAYMENTS (Get these from Razorpay Dashboard) ---
RAZORPAY_KEY_ID=rzp_live_your-key-id
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
# The Plan ID for your subscription (create this in Razorpay Dashboard)
RAZORPAY_PLAN_ID=plan_your-plan-id

# --- FRONTEND (For .env.local on Vercel) ---
REACT_APP_API_URL=https://your-audio-backend.onrender.com
